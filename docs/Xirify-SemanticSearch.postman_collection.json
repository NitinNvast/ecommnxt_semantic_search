{
  "info": {
    "name": "Xirify Semantic Search",
    "_postman_id": "xirify-semantic-search-v1",
    "description": "Full API collection for the Xirify Semantic Search microservice (FastAPI, port 8001).\n\n**Variables (set in collection or environment):**\n- `base_url` — e.g. `http://localhost:8001`\n- `jwt_token` — HS256 JWT signed with `JWT_SECRET`\n- `internal_api_key` — value of `INTERNAL_API_KEY` in .env",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",         "value": "http://localhost:8001", "type": "string" },
    { "key": "jwt_token",        "value": "YOUR_JWT_TOKEN_HERE",  "type": "string" },
    { "key": "internal_api_key", "value": "internal-secret-here", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns the status of MongoDB, Qdrant, Redis, and the outbox queue depth. No auth required."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"status\": \"ok\",\n  \"mongo\": \"ok\",\n  \"qdrant\": \"ok\",\n  \"redis\": \"ok\",\n  \"outbox_pending\": 0,\n  \"outbox_dead\": 0\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Semantic Search — Basic",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/search",
              "host": ["{{base_url}}"],
              "path": ["search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"best pizza near me\",\n  \"entities\": [\"business\", \"service\"],\n  \"page\": 1,\n  \"limit\": 20\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Basic semantic search — no geo filter, no extra filters. Returns businesses and services ranked by vector similarity + quality score."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"results\": [\n    {\n      \"entityType\": \"business\",\n      \"id\": \"64a1b2c3d4e5f6a7b8c9d0e1\",\n      \"score\": 0.91,\n      \"distanceKm\": null,\n      \"business\": null,\n      \"highlight\": {\n        \"name\": \"Pizza Palace\",\n        \"price\": null,\n        \"description\": \"Authentic wood-fired pizza\"\n      }\n    }\n  ],\n  \"fallbackUsed\": false,\n  \"total\": 1,\n  \"tookMs\": 120\n}"
            }
          ]
        },
        {
          "name": "Semantic Search — With Geo Filter",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/search",
              "host": ["{{base_url}}"],
              "path": ["search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"biryani restaurant\",\n  \"entities\": [\"business\", \"service\"],\n  \"geo\": {\n    \"lat\": 18.5204,\n    \"lng\": 73.8567,\n    \"radiusKm\": 5.0\n  },\n  \"page\": 1,\n  \"limit\": 20\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Search with geo filter. Results are scored with proximity decay (exponential, 2 km half-life). radiusKm defaults to 5.0."
          }
        },
        {
          "name": "Semantic Search — With All Filters",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/search",
              "host": ["{{base_url}}"],
              "path": ["search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"wireless earbuds\",\n  \"entities\": [\"service\"],\n  \"geo\": {\n    \"lat\": 18.5204,\n    \"lng\": 73.8567,\n    \"radiusKm\": 3.0\n  },\n  \"filters\": {\n    \"category\": \"Electronics\",\n    \"priceMax\": 300.0,\n    \"serviceModes\": [\"delivery\", \"pickup\"]\n  },\n  \"page\": 1,\n  \"limit\": 10\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Search with all optional filters: geo, category, priceMax, serviceModes. entities can be [\"business\"], [\"service\"], or both."
          }
        },
        {
          "name": "Semantic Search — Business Only",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/search",
              "host": ["{{base_url}}"],
              "path": ["search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"hair salon near me\",\n  \"entities\": [\"business\"],\n  \"geo\": {\n    \"lat\": 18.5204,\n    \"lng\": 73.8567,\n    \"radiusKm\": 5.0\n  },\n  \"page\": 1,\n  \"limit\": 20\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Restrict search to businesses only."
          }
        },
        {
          "name": "Semantic Search — Pagination",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/search",
              "host": ["{{base_url}}"],
              "path": ["search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"coffee shop\",\n  \"entities\": [\"business\", \"service\"],\n  \"page\": 2,\n  \"limit\": 10\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Page 2, 10 results per page. page >= 1, limit 1–100."
          }
        }
      ]
    },
    {
      "name": "Internal — Reindex",
      "item": [
        {
          "name": "Reindex Single Entity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Internal-Key", "value": "{{internal_api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/internal/reindex/business/64a1b2c3d4e5f6a7b8c9d0e1",
              "host": ["{{base_url}}"],
              "path": ["internal", "reindex", "business", "64a1b2c3d4e5f6a7b8c9d0e1"]
            },
            "description": "Force-reindex a single entity. entity_type must be one of: business | service. Runs in the background — returns a jobId immediately.\n\nURL pattern: /internal/reindex/{entity_type}/{entity_id}"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"jobId\": \"b3d2e1f0-1234-5678-abcd-ef0123456789\",\n  \"message\": \"Re-index queued for business/64a1b2c3d4e5f6a7b8c9d0e1\"\n}"
            }
          ]
        },
        {
          "name": "Reindex Single Service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Internal-Key", "value": "{{internal_api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/internal/reindex/service/64a1b2c3d4e5f6a7b8c9d0e3",
              "host": ["{{base_url}}"],
              "path": ["internal", "reindex", "service", "64a1b2c3d4e5f6a7b8c9d0e3"]
            },
            "description": "Reindex a single service entity."
          }
        },
        {
          "name": "Reindex All Services for a Business",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Internal-Key", "value": "{{internal_api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/internal/reindex/business/64a1b2c3d4e5f6a7b8c9d0e1/services",
              "host": ["{{base_url}}"],
              "path": ["internal", "reindex", "business", "64a1b2c3d4e5f6a7b8c9d0e1", "services"]
            },
            "description": "Fan-out reindex: finds all services belonging to the given businessId and re-indexes each one. Runs in the background."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"jobId\": \"c4e3f2a1-abcd-1234-5678-fedcba987654\",\n  \"message\": \"Fan-out reindex queued for business 64a1b2c3d4e5f6a7b8c9d0e1\"\n}"
            }
          ]
        },
        {
          "name": "Bulk Reindex — All Businesses",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",   "value": "application/json" },
              { "key": "X-Internal-Key", "value": "{{internal_api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/internal/bulk-reindex",
              "host": ["{{base_url}}"],
              "path": ["internal", "bulk-reindex"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity\": \"business\",\n  \"filter\": {},\n  \"reason\": \"full reindex after model upgrade\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Bulk reindex all documents of an entity type. filter is a MongoDB query dict — use {} for all. Runs in the background."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"jobId\": \"d5f4a3b2-1111-2222-3333-444455556666\",\n  \"message\": \"Bulk reindex queued for business — full reindex after model upgrade\"\n}"
            }
          ]
        },
        {
          "name": "Bulk Reindex — Filtered Services",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",   "value": "application/json" },
              { "key": "X-Internal-Key", "value": "{{internal_api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/internal/bulk-reindex",
              "host": ["{{base_url}}"],
              "path": ["internal", "bulk-reindex"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity\": \"service\",\n  \"filter\": {\n    \"isEnabled\": true,\n    \"isDisplay\": true\n  },\n  \"reason\": \"reindex all active services\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Bulk reindex with a MongoDB filter. Only documents matching the filter will be queued."
          }
        }
      ]
    },
    {
      "name": "Internal — Status",
      "item": [
        {
          "name": "Embedding Status — Business",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Internal-Key", "value": "{{internal_api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/internal/embedding-status/business/64a1b2c3d4e5f6a7b8c9d0e1",
              "host": ["{{base_url}}"],
              "path": ["internal", "embedding-status", "business", "64a1b2c3d4e5f6a7b8c9d0e1"]
            },
            "description": "Check whether a business has been indexed in Qdrant and if its embedding is in sync.\n\nURL pattern: /internal/embedding-status/{entity_type}/{entity_id}"
          },
          "response": [
            {
              "name": "200 — Indexed & in sync",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"exists\": true,\n  \"embedding_version\": \"text-embedding-3-small\",\n  \"source_hash\": \"abc123def456\",\n  \"updated_at\": \"2026-06-01T10:30:00Z\",\n  \"inSync\": true\n}"
            },
            {
              "name": "200 — Not indexed",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"exists\": false,\n  \"embedding_version\": null,\n  \"source_hash\": null,\n  \"updated_at\": null,\n  \"inSync\": false\n}"
            }
          ]
        },
        {
          "name": "Embedding Status — Service",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Internal-Key", "value": "{{internal_api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/internal/embedding-status/service/64a1b2c3d4e5f6a7b8c9d0e3",
              "host": ["{{base_url}}"],
              "path": ["internal", "embedding-status", "service", "64a1b2c3d4e5f6a7b8c9d0e3"]
            },
            "description": "Check embedding status for a service entity."
          }
        }
      ]
    }
  ]
}
