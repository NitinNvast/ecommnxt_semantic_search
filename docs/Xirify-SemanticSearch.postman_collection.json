{
  "info": {
    "name": "Xirify Semantic Search",
    "_postman_id": "xirify-semantic-search-v1",
    "description": "Full API collection for the Xirify Semantic Search microservice (FastAPI, port 8001).\n\n**Variables (set in collection or environment):**\n- `base_url` — e.g. `http://localhost:8001`\n- `jwt_token` — HS256 JWT signed with `JWT_SECRET`\n- `internal_api_key` — value of `INTERNAL_API_KEY` in .env",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",         "value": "http://localhost:8001", "type": "string" },
    { "key": "jwt_token",        "value": "YOUR_JWT_TOKEN_HERE",  "type": "string" },
    { "key": "internal_api_key", "value": "internal-secret-here", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns the status of MongoDB, Qdrant, Redis, and the outbox queue depth. No auth required."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"status\": \"ok\",\n  \"mongo\": \"ok\",\n  \"qdrant\": \"ok\",\n  \"redis\": \"ok\",\n  \"outbox_pending\": 0,\n  \"outbox_dead\": 0\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Semantic Search — Basic",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/search",
              "host": ["{{base_url}}"],
              "path": ["search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"best pizza near me\",\n  \"page\": 1,\n  \"limit\": 20\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Basic semantic search on services — no geo filter, no extra filters. Results are ranked by vector similarity fused with text search (RRF) and a quality score."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"results\": [\n    {\n      \"entityType\": \"service\",\n      \"id\": \"64a1b2c3d4e5f6a7b8c9d0e3\",\n      \"score\": 0.88,\n      \"distanceKm\": null,\n      \"business\": {\n        \"id\": \"64a1b2c3d4e5f6a7b8c9d0e1\",\n        \"name\": \"Pizza Palace\",\n        \"rating\": 4.5,\n        \"xirifyAssured\": true\n      },\n      \"highlight\": {\n        \"name\": \"Margherita Pizza\",\n        \"price\": 250.0,\n        \"description\": \"Classic wood-fired margherita with fresh basil\"\n      }\n    }\n  ],\n  \"fallbackUsed\": false,\n  \"total\": 1,\n  \"tookMs\": 120\n}"
            }
          ]
        },
        {
          "name": "Semantic Search — With Geo Filter",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/search",
              "host": ["{{base_url}}"],
              "path": ["search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"biryani\",\n  \"geo\": {\n    \"lat\": 18.5204,\n    \"lng\": 73.8567,\n    \"radiusKm\": 5.0\n  },\n  \"page\": 1,\n  \"limit\": 20\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Search services within a geo radius. Results are scored with proximity decay (exponential, 2 km half-life). `radiusKm` defaults to 5.0."
          }
        },
        {
          "name": "Semantic Search — With Category Filter",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/search",
              "host": ["{{base_url}}"],
              "path": ["search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"wireless earbuds\",\n  \"geo\": {\n    \"lat\": 18.5204,\n    \"lng\": 73.8567,\n    \"radiusKm\": 3.0\n  },\n  \"filters\": {\n    \"category\": \"Electronics\",\n    \"priceMax\": 3000.0,\n    \"serviceModes\": [\"delivery\", \"pickup\"]\n  },\n  \"page\": 1,\n  \"limit\": 10\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Search with all optional filters: geo, category, priceMax, serviceModes."
          }
        },
        {
          "name": "Semantic Search — Pagination",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/search",
              "host": ["{{base_url}}"],
              "path": ["search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"coffee\",\n  \"page\": 2,\n  \"limit\": 10\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Page 2, 10 results per page. `page` >= 1, `limit` 1–100."
          }
        }
      ]
    },
    {
      "name": "Internal — Reindex",
      "item": [
        {
          "name": "Reindex Single Service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Internal-Key", "value": "{{internal_api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/internal/reindex/service/64a1b2c3d4e5f6a7b8c9d0e3",
              "host": ["{{base_url}}"],
              "path": ["internal", "reindex", "service", "64a1b2c3d4e5f6a7b8c9d0e3"]
            },
            "description": "Force-reindex a single service by ID. Runs in the background — returns a jobId immediately.\n\nURL pattern: `/internal/reindex/service/{entity_id}`"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"jobId\": \"b3d2e1f0-1234-5678-abcd-ef0123456789\",\n  \"message\": \"Re-index queued for service/64a1b2c3d4e5f6a7b8c9d0e3\"\n}"
            }
          ]
        },
        {
          "name": "Reindex All Services for a Business",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Internal-Key", "value": "{{internal_api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/internal/reindex/business/64a1b2c3d4e5f6a7b8c9d0e1/services",
              "host": ["{{base_url}}"],
              "path": ["internal", "reindex", "business", "64a1b2c3d4e5f6a7b8c9d0e1", "services"]
            },
            "description": "Fan-out reindex: finds all services belonging to the given `businessId` and re-indexes each one. Useful when a business's geo or metadata changes. Runs in the background.\n\nURL pattern: `/internal/reindex/business/{business_id}/services`"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"jobId\": \"c4e3f2a1-abcd-1234-5678-fedcba987654\",\n  \"message\": \"Fan-out reindex queued for business 64a1b2c3d4e5f6a7b8c9d0e1\"\n}"
            }
          ]
        },
        {
          "name": "Bulk Reindex — All Services",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",   "value": "application/json" },
              { "key": "X-Internal-Key", "value": "{{internal_api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/internal/bulk-reindex",
              "host": ["{{base_url}}"],
              "path": ["internal", "bulk-reindex"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity\": \"service\",\n  \"filter\": {},\n  \"reason\": \"full reindex after model upgrade\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Bulk reindex all services. `filter` is reserved for future use (pass `{}` for all). Runs in the background."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"jobId\": \"d5f4a3b2-1111-2222-3333-444455556666\",\n  \"message\": \"Bulk reindex queued for service — full reindex after model upgrade\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Internal — Status",
      "item": [
        {
          "name": "Embedding Status — Service",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Internal-Key", "value": "{{internal_api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/internal/embedding-status/service/64a1b2c3d4e5f6a7b8c9d0e3",
              "host": ["{{base_url}}"],
              "path": ["internal", "embedding-status", "service", "64a1b2c3d4e5f6a7b8c9d0e3"]
            },
            "description": "Check whether a service has been indexed in Qdrant and if its embedding is in sync with the current source text.\n\nURL pattern: `/internal/embedding-status/service/{entity_id}`"
          },
          "response": [
            {
              "name": "200 — Indexed & in sync",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"exists\": true,\n  \"embedding_version\": \"v1-te3s\",\n  \"source_hash\": \"abc123def456\",\n  \"updated_at\": \"2026-06-01T10:30:00Z\",\n  \"inSync\": true\n}"
            },
            {
              "name": "200 — Not indexed",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"exists\": false,\n  \"embedding_version\": null,\n  \"source_hash\": null,\n  \"updated_at\": null,\n  \"inSync\": false\n}"
            }
          ]
        }
      ]
    }
  ]
}
